# DGX Spark Monitoring Stack - Environment Variables
# Copy this file to .env and update with host-specific values.

# -----------------------------------------------------------------------------
# Core configuration (required for every deployment)
# -----------------------------------------------------------------------------
# Unique identifier for this machine. Appears in all metrics.
HOSTNAME=spark-1

# Central Prometheus remote-write endpoint
# Example for private VPC connectivity:
# CENTRAL_PROMETHEUS_URL=http://10.116.0.2:9090/api/v1/write

# Example for HTTPS + Basic Auth:
CENTRAL_PROMETHEUS_URL=https://monitoring.example.com/prometheus/api/v1/write
BASIC_AUTH_USER=remote
BASIC_AUTH_PASSWORD=your-password-here

# -----------------------------------------------------------------------------
# Optional: vLLM metrics
# -----------------------------------------------------------------------------
# If vLLM is running on this host, set its metrics endpoint here to enable
# the scrape job. Leave empty to disable (no scrape errors will occur).
# vLLM must run with network_mode=host or publish its port on the host.
# Default vLLM OpenAI API server port is 8000.
# VLLM_METRICS_TARGET=host.docker.internal:8000

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Leave BASIC_AUTH_* blank when connecting over private networks (VPC).
# - HOSTNAME must be unique across all monitored machines.
# - nv-monitor runs as a native systemd service (not part of Docker Compose).
#   See nv-monitor/nv-monitor.service for the unit file template.
# - Rebuild the stack after changing VLLM_METRICS_TARGET: docker compose up -d --build
